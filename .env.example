# =============================================================================
# Gemini (Google Generative AI) — drives generateText / reviewText / generateTextStream /
# reviewTextStream in lib/ai.ts. Provider abstracted behind those helpers; swapping vendors
# is a one-file change.
# =============================================================================
GEMINI_API_KEY=
# Default model for all stages except the heavy text-generator drafting pass.
GEMINI_MODEL_DEFAULT=gemini-2.5-flash
# Review/critique model (zachgpt-review, pr-reviewer).
GEMINI_MODEL_REVIEW=gemini-2.5-flash
# Heavy drafting stage — pinned to gemini-2.5-pro for the text-generator step
# (both main blog + standalone "custom blog" pipelines).
GEMINI_MODEL_TEXTGEN=gemini-2.5-pro

# =============================================================================
# OpenAI (used for web search via gpt-4o-search-preview, and JSON outline calls)
# =============================================================================
OPENAI_API_KEY=sk-...
OPENAI_SEARCH_MODEL=gpt-4o-search-preview

# =============================================================================
# Educative publishing
# =============================================================================
# flask-auth cookie value (do NOT include the "flask-auth=" prefix)
EDUCATIVE_FLASK_AUTH=
# Separate session cookie for course/collection API (from SD Path cookies)
EDUCATIVE_COURSE_FLASK_AUTH=
# Author ID used when publishing content
EDUCATIVE_AUTHOR_ID=
# Optional: D2 SVG generator path (e.g. /api/author/.../d2/generate). Leave empty to skip server-side D2 rendering.
EDUCATIVE_D2_PATH=
